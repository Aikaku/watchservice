# AI 서버 환경변수 예시
# Railway / Render 대시보드의 Variables 탭에서 설정

# 백엔드(Spring Boot)가 배포된 도메인
# Electron 앱이라면 Electron 앱 내 로컬호스트 → 클라우드 AI 서버를 가리키는 URL 불필요
# Spring Boot → AI 서버 방향이므로 Spring Boot 서버 도메인을 허용
CORS_ALLOWED_ORIGINS=https://your-spring-boot-domain.com

# 모델/아티팩트 경로 (기본값 사용 시 설정 불필요)
# OUTPUT_DIR=./artifacts
# CONFIG_PATH=configs/config.yaml
